---
import ArrowIcon from "./ArrowIcon.astro";

const { href, label } = Astro.props;
---

<a
  class="inline-flex items-center gap-2 text-[var(--fg-muted)] transition-colors hover:text-[var(--fg)] underline decoration-dotted underline-offset-[0.2em] decoration-[var(--line)]"
  rel="noopener noreferrer"
  target="_blank"
  href={href}
>
  <ArrowIcon />
  <span class="leading-none py-1">{label}</span>
</a>
