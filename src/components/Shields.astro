---
interface ShieldData {
  label: string;
  color: string;
  icon: string;
  iconColor?: string;
}

const shields: ShieldData[] = [
  {
    label: "node.js",
    color: "5FA04E",
    icon: "nodedotjs",
  },
  {
    label: "nestjs",
    color: "E0234E",
    icon: "nestjs",
  },
  {
    label: "typescript",
    color: "3178C6",
    icon: "typescript",
  },
  {
    label: "postgres",
    color: "4169E1",
    icon: "postgresql",
  },
  {
    label: "mongodb",
    color: "47A248",
    icon: "mongodb",
  },
  {
    label: "docker",
    color: "2496ED",
    icon: "docker",
  },
  {
    label: "linux",
    color: "FCC624",
    icon: "linux",
    iconColor: "black",
  },
  {
    label: "aws",
    color: "232F3E",
    icon: "amazonwebservices",
  },
  {
    label: "terraform",
    color: "844FBA",
    icon: "terraform",
  },
  {
    label: "cloudflare",
    color: "F38020",
    icon: "cloudflare",
  },
  {
    label: "openai",
    color: "412991",
    icon: "openai",
  },
  {
    label: "next.js",
    color: "000000",
    icon: "nextdotjs",
  },
  {
    label: "react",
    color: "61DAFB",
    icon: "react",
  },
  {
    label: "tailwind",
    color: "06B6D4",
    icon: "tailwindcss",
  },
];

const style = "for-the-badge";

const constructShieldUrl = (shield: ShieldData) =>
  `https://img.shields.io/badge/${shield.label}-${shield.color}?style=${style}&logo=${shield.icon}&logoColor=${shield.iconColor ?? "white"}`;
---

<div>
  <p
    class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--fg-muted)] mb-3"
  >
    Stack
  </p>
  <div
    class="rounded-sm border border-dotted [border-color:var(--line)] bg-[var(--bg-elevated)] p-4"
  >
    <div class="flex flex-wrap gap-2 opacity-90 contrast-[0.97]">
      {shields.map((shield) => <img src={constructShieldUrl(shield)} alt="" />)}
    </div>
  </div>
</div>
