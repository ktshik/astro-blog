---
interface ShieldData {
  label: string;
  color: string;
  icon: string;
  iconColor?: string;
}

interface ShieldCategory {
  title: string;
  shields: ShieldData[];
}

const categories: ShieldCategory[] = [
  {
    title: "Languages",
    shields: [
      { label: "node.js", color: "5FA04E", icon: "nodedotjs" },
      { label: "typescript", color: "3178C6", icon: "typescript" },
    ],
  },
  // {
  //   title: "Frameworks",
  //   shields: [
  //     { label: "nestjs", color: "E0234E", icon: "nestjs" },
  //     { label: "next.js", color: "000000", icon: "nextdotjs" },
  //     { label: "react", color: "61DAFB", icon: "react" },
  //     { label: "tailwind", color: "06B6D4", icon: "tailwindcss" },
  //   ],
  // },
  {
    title: "Data",
    shields: [
      { label: "postgres", color: "4169E1", icon: "postgresql" },
      { label: "mongodb", color: "47A248", icon: "mongodb" },
      { label: "redis", color: "FF4438", icon: "redis" },
      { label: "bigquery", color: "669DF6", icon: "googlebigquery" },
    ],
  },
  {
    title: "Infrastructure",
    shields: [
      { label: "docker", color: "2496ED", icon: "docker" },
      { label: "aws", color: "232F3E", icon: "amazonwebservices" },
      { label: "gcp", color: "4285F4", icon: "googlecloud" },
      { label: "terraform", color: "844FBA", icon: "terraform" },
      { label: "cloudflare", color: "F38020", icon: "cloudflare" },
    ],
  },
  {
    title: "AI",
    shields: [
      { label: "cursor", color: "000000", icon: "cursor" },
      { label: "claude", color: "D97757", icon: "claude" },
      { label: "openai", color: "412991", icon: "openai" },
    ],
  },
];

const style = "for-the-badge";

const constructShieldUrl = (shield: ShieldData) =>
  `https://img.shields.io/badge/${shield.label}-${shield.color}?style=${style}&logo=${shield.icon}&logoColor=${shield.iconColor ?? "white"}`;
---

<div class="flex flex-col gap-2">
  {
    categories.map((category) => (
      <div>
        <p class="text-[0.7125rem] font-medium uppercase tracking-[0.18em] text-[var(--fg-muted)] mb-1">
          {category.title}
        </p>
        <div class="flex flex-wrap gap-1 opacity-90 contrast-[0.97]">
          {category.shields.map((shield) => (
            <img src={constructShieldUrl(shield)} alt="" />
          ))}
        </div>
      </div>
    ))
  }
</div>
