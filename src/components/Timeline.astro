---
import dayjs from "dayjs";
interface TimelineStep {
  startDate: dayjs.Dayjs | string;
  endDate?: dayjs.Dayjs | string;
  title: string;
  company: string;
  description?: string;
  extra?: string;
}
const timelineSteps: TimelineStep[] = [
  {
    startDate: dayjs("mar 2025"),
    title: "Product Backend Engineer",
    company: "Fizz",
    description:
      "Building authentic digital spaces for Gen Z.",
  },
  {
    startDate: dayjs("nov 2023"),
    title: "CTO & Co-founder",
    company: "Ambit Labs",
    description:
      "Developer of an all-in-one marketing suite for digital entrepreneurs.",
  },
];

const formatDate = (date: dayjs.Dayjs | string) =>
  typeof date === "string" ? date : date.format("MMMM YYYY");
---

<div>
  <p
    class="text-xs font-medium uppercase tracking-[0.2em] text-[var(--fg-muted)] mb-4"
  >
    Experience
  </p>
  <ol
    class="relative border-s border-dotted [border-color:var(--line)] ms-1.5"
  >
    {
      timelineSteps.map((timelineStep) => (
        <li class="relative mb-10 ms-5 last:mb-0">
          <div
            class="absolute w-2 h-2 rounded-full mt-1.5 -start-[5px] border border-dotted [border-color:var(--line)] bg-[var(--bg-elevated)]"
          />
          <time class="mb-1 block text-sm font-normal leading-none text-[var(--fg-muted)] tabular-nums">
            {formatDate(timelineStep.startDate)}
            {timelineStep.endDate && ` — ${formatDate(timelineStep.endDate)}`}
          </time>
          <h3 class="text-base font-medium text-[var(--fg)] !mb-1 tracking-tight">
            {timelineStep.title}
            <span class="font-normal text-[var(--fg-muted)]">
              {" "}
              — {timelineStep.company}
            </span>
          </h3>
          <p class="text-[15px] font-normal leading-relaxed text-[var(--fg-muted)]">
            {timelineStep.description}
          </p>
          {timelineStep.extra}
        </li>
      ))
    }
  </ol>
</div>
