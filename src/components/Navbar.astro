---
import classnames from "classnames";
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;

const navItems = {
  "/": {
    name: "Home",
  },
  "/blog": {
    name: "Blog",
  },
};
---

<header class="pb-6 mb-2 border-b border-dotted [border-color:var(--line)]">
  <div class="flex flex-row flex-wrap items-center justify-between gap-4">
    <nav
      class="flex flex-row items-center gap-6 text-sm font-medium tracking-wide text-[var(--fg-muted)]"
      aria-label="Primary"
    >
      {
        Object.entries(navItems).map(([path, { name }]) => (
          <a
            class={classnames(
              "py-1 transition-colors hover:text-[var(--fg)]",
              path === pathname && "text-[var(--fg)]"
            )}
            href={path}
          >
            {name}
          </a>
        ))
      }
    </nav>
    <ThemeToggle />
  </div>
</header>
