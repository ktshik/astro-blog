---
import classNames from 'classnames';

interface Props {
  title: string;
  id?: string;
  class?: string;
}

const { title, id, class: className } = Astro.props;
const headingId = id ?? `home-${title.toLowerCase().replace(/\s+/g, "-")}`;
---

<section class={classNames("home-section", className)} aria-labelledby={headingId}>
  <div class="section">
    <p
      id={headingId}
      class="text-sm font-medium uppercase tracking-[0.18em] text-[var(--fg-muted)] mb-3"
    >
      {title}
  </p>
    <slot />
  </div>
</section>
