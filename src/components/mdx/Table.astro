---
const { data } = Astro.props;
---

<table class="border-collapse text-sm">
  <thead>
    <tr>
      {
        data.headers.map((header: string) => (
          <th class="border border-dotted p-2 [border-color:var(--line)] font-medium text-[var(--fg)]">
            {header}
          </th>
        ))
      }</tr
    >
  </thead>
  <tbody
    >{
      data.rows.map((row: string[]) => (
        <tr>
          {row.map((cell) => (
            <td class="border border-dotted p-2 [border-color:var(--line)] text-[var(--fg-muted)]">
              {cell}
            </td>
          ))}
        </tr>
      ))
    }</tbody
  >
</table>
