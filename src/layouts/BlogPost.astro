---
import type { CollectionEntry } from "astro:content";
import BackArrowIcon from "../components/BackArrowIcon.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Root from "./Root.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<Root title={title} description={description} image={heroImage}>
  <a
    class="inline-flex items-center gap-2 py-1.5 -mt-1 mb-5 text-sm text-[var(--fg-muted)] transition-colors hover:text-[var(--fg)]"
    href="/blog"
  >
    <BackArrowIcon /><span class="underline decoration-dotted underline-offset-4">Back to posts</span>
  </a>
  <article>
    <div class="hero-image !mb-5">
      {
        heroImage && (
          <img
            class="w-full h-[240px] object-cover rounded-sm border border-dotted [border-color:var(--line)]"
            src={heroImage}
            alt=""
          />
        )
      }
    </div>
    <div class="prose">
      <div class="title !mb-8 pb-6 border-b border-dotted [border-color:var(--line)]">
        <h1>{title}</h1>
        <div class="date mt-3 text-sm text-[var(--fg-muted)] tabular-nums">
          <FormattedDate date={pubDate} />
          {
            updatedDate && (
              <div class="last-updated-on mt-1">
                Last updated on <FormattedDate date={updatedDate} />
              </div>
            )
          }
        </div>
      </div>
      <slot />
    </div>
  </article>
</Root>
