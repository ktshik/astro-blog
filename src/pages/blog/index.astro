---
import { getCollection } from "astro:content";
import Root from "../../layouts/Root.astro";
import { formatDate } from "../../util";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Root>
  <section>
    <h1 class="my-2 mb-6 tracking-tight">Blog</h1>
    <ul class="divide-y divide-dotted divide-[var(--line)]">
      {
        posts.map((post) => (
          <li class="py-4 first:pt-0">
            <a
              class="group flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-8"
              href={`/blog/${post.id}`}
            >
              <time
                class="shrink-0 text-sm tabular-nums text-[var(--fg-muted)] sm:w-[7.5rem]"
                datetime={post.data.pubDate.toISOString()}
              >
                {formatDate(post.data.pubDate.toString(), false)}
              </time>
              <span class="text-[var(--fg)] tracking-tight group-hover:underline decoration-dotted underline-offset-4">
                {post.data.title}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Root>
