---
import HomeSection from "../components/HomeSection.astro";
import HudFrame from "../components/HudFrame.astro";
import Links from "../components/Links.astro";
import Shields from "../components/Shields.astro";
import Timeline from "../components/Timeline.astro";
import Root from "../layouts/Root.astro";
---

<Root>
  <section class="portfolio-page flex w-full min-w-0 flex-col gap-12">
    <div class="portfolio-hero-enter flex flex-col gap-6">
      <HudFrame class="hud-frame--flush">
        <div class="px-5 py-6 sm:px-7 sm:py-7">
          <p
            class="font-[JetBrains_Mono] text-[0.75rem] font-medium uppercase tracking-[0.28em] text-[var(--accent-orange)] mb-3"
          >
            Portfolio / Systems
          </p>
          <h1 class="!mb-2 font-[JetBrains_Mono] text-4xl sm:text-5xl font-semibold tracking-tight text-[var(--fg)]">
            ktshik
          </h1>
          <p class="font-[JetBrains_Mono] text-base text-[var(--fg-muted)] mb-4">
            backend · infra · product engineering
          </p>
          <p class="text-xl leading-relaxed text-[var(--fg-muted)] max-w-prose border-t border-[var(--line)] pt-5">
            I design and ship <strong class="font-semibold text-[var(--fg)]"
              >reliable systems</strong
            >: APIs, data pipelines, and cloud infrastructure — with attention to
            performance, observability, and maintainability.
          </p>
        </div>
      </HudFrame>
    </div>
    <HomeSection title="Contact">
      <Links />
    </HomeSection>
    <HomeSection title="Stack">
      <Shields />
    </HomeSection>
    <HomeSection title="Experience">
      <Timeline />
    </HomeSection>
  </section>
</Root>
